{
  "nas": {
    "hostname": "truenas",
    "ips": {
      "server_vlan": "10.10.10.50",
      "client_vlan": "10.10.20.50"
    },
    "local": {
      "postgres_disk": {
        "device": "/dev/sdb",
        "mountpoint": "/var/mnt/postgres",
        "description": "Dedicate Zvol for CloudNativePG",
        "size": "100Gi",
        "fs": "XFS (Formatted by Talos)",
        "provisioner": "rancher.io/local-path",
        "nodes": [
          "talos-cp-01",
          "talos-cp-02",
          "talos-cp-03"
        ]
      }
    },
    "exports": {
      "k8s_arr": {
        "path": "/mnt/stripe/k8s-arr",
        "description": "Kubernetes PVCs for Arr stack (Config / SQLite)",
        "protocol": "nfs",
        "mount_options": [
          "nfsvers=4.1",
          "soft",
          "timeo=50",
          "retrans=3",
          "noatime"
        ],
        "networks": [
          "10.10.10.0/24",
          "10.10.20.0/24"
        ]
      },
      "media": {
        "path": "/mnt/oliraid/arrdata/media",
        "description": "Mass Storage for Media Library",
        "protocol": "nfs",
        "mount_options": [
          "nfsvers=4.1",
          "soft",
          "timeo=50",
          "retrans=3",
          "noatime"
        ],
        "networks": [
          "10.10.20.141",
          "10.10.20.142",
          "10.10.20.143",
          "10.10.10.0/24"
        ]
      },
      "backup_proxmox": {
        "path": "/mnt/oliraid/backup-proxmox",
        "description": "Legacy Proxmox VZDump Backups (Archive)",
        "protocol": "nfs",
        "networks": [
          "10.10.10.0/24"
        ]
      },
      "pbs_store": {
        "path": "/mnt/oliraid/pbs-store",
        "description": "Proxmox Backup Server Datastore (Chunk-based)",
        "protocol": "nfs",
        "networks": [
          "10.10.10.0/24"
        ]
      },
      "backup_k8s_arr": {
        "path": "/mnt/oliraid/backup-stripe",
        "description": "Replica Target for Stripe (ZFS Snapshots)",
        "protocol": "zfs-replication",
        "networks": []
      }
    }
  }
}