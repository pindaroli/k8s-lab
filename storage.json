        "protocol": "nfs",
        "networks": [
          "10.10.10.0/24",
          "10.10.20.0/24"
        ]
      },
      "k8s_fast_gen": {
        "path": "/mnt/stripe/k8s-fast-gen",
        "description": "Fast Storage for General workloads",
        "protocol": "nfs",
        "networks": [
          "10.10.10.0/24",
          "10.10.20.0/24"
        ]
      }
    }
  }
}