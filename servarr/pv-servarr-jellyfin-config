apiVersion: v1
kind: PersistentVolume
metadata:
  name: pv-servarr-jellyfin-config
  labels:
    app.kubernetes.io/instance: servarr
    app.kubernetes.io/name: jellyfin
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: nfs-csi
  volumeMode: Filesystem
  csi:
    driver: nfs.csi.k8s.io
    volumeHandle: pv-servarr-jellyfin-config
    volumeAttributes:
      server: 192.168.1.115
      share: /mnt/oliraid/k8s-disk/servarr-jellyfin-config
