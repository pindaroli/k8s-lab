apiVersion: v1
kind: Secret
metadata:
  name: grafana-admin-secret
  namespace: monitoring
  labels:
    app.kubernetes.io/part-of: victoria-metrics-stack
type: Opaque
stringData:
  admin-user: admin
  # SOSTITUIRE con password sicura prima del deploy:
  # openssl rand -base64 24
  admin-password: "CHANGE_ME_BEFORE_DEPLOY"
