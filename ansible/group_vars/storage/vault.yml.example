# Example vault file for TrueNAS credentials
# To create your actual vault file:
# 1. Copy this file: cp vault.yml.example vault.yml
# 2. Edit vault.yml with your actual API key
# 3. Encrypt it: ansible-vault encrypt vault.yml
# 4. Use it in playbooks with: --ask-vault-pass

vault_truenas_api_key: "your-api-key-here"
